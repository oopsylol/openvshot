# Copy this file to .mac-signing.env on your Mac and fill in only one notarization method.
# Formal distribution requires both a Developer ID signing identity and one notarization method.

# Optional build settings
# export PYTHON_BIN="python3"
# export OPENVSHOT_MAC_ARCH="universal"
# export OPENVSHOT_ICON_SOURCE="/absolute/path/to/1024-icon.png"
# export OPENVSHOT_REQUIRE_SIGNED_RELEASE="1"

# Required for formal distribution: Developer ID Application signing identity
# export CSC_NAME="Developer ID Application: Your Company (TEAMID12345)"
# export CSC_IDENTITY_AUTO_DISCOVERY=true

# Recommended notarization method: App Store Connect API key
# export APPLE_API_KEY="/absolute/path/to/AuthKey_ABC123XYZ.p8"
# export APPLE_API_KEY_ID="ABC123XYZ"
# export APPLE_API_ISSUER="00000000-0000-0000-0000-000000000000"

# Fallback notarization method: Apple ID + app-specific password
# export APPLE_ID="name@example.com"
# export APPLE_APP_SPECIFIC_PASSWORD="abcd-efgh-ijkl-mnop"
# export APPLE_TEAM_ID="TEAMID1234"

# Alternative notarization method: notarytool keychain profile
# export APPLE_KEYCHAIN_PROFILE="OpenVshotNotary"
# export APPLE_KEYCHAIN="/Users/you/Library/Keychains/login.keychain-db"
